# ─────────────────────────────────────────────────────────────
# Behind The Code environment variables
# Copy to .env.local (for local dev) and fill in.
# Only the "Core" section is required to boot the app.
# ─────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
# Supabase (database, auth, storage). https://supabase.com/dashboard
# Project Settings -> API Keys. Use the new API keys (recommended).
#
# NOTE (Vite/Cloudflare): browser-exposed vars MUST be prefixed VITE_ (Vite
# only inlines VITE_* into the client bundle — this replaces NEXT_PUBLIC_*).
# Server code reads these same VITE_* names from process.env at runtime
# (Worker vars via nodejs_compat), so set them once here.
#
# Project URL (used by browser + server).
VITE_SUPABASE_URL=
# Also set SUPABASE_URL to the same value — the @btc/db service-role client
# (server-only data layer) reads SUPABASE_URL.
SUPABASE_URL=
# Publishable key (sb_publishable_...) — safe to expose to the browser.
VITE_SUPABASE_PUBLISHABLE_KEY=
# Secret key (sb_secret_...) — server-only, NEVER expose to the browser.
SUPABASE_SECRET_KEY=
#
# Legacy fallback (older local CLI / pre-migration projects):
# SUPABASE_SERVICE_ROLE_KEY=

# Mux (video). https://dashboard.mux.com/settings/access-tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Signing secret for the Mux webhook (Settings -> Webhooks)
MUX_WEBHOOK_SECRET=

# Public base URL of the app (browser + server).
VITE_APP_URL=http://localhost:3000

# Cron secret used to authorize the scheduled-publish endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Initial admin (used by `bun run seed` / `bun run seed:admin`).
# The first account to sign up also automatically becomes an admin.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# ── Optional sign-in providers (each auto-enables its method) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# X (Twitter) OAuth — uses Supabase's `twitter` provider.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Magic link (passwordless). Requires both.
RESEND_API_KEY=
EMAIL_FROM=

# ── Optional AI comment moderation ────────────────────────────
# Set to "true" to enable. Requires an AI provider key.
AI_MODERATION_ENABLED=
OPENAI_API_KEY=

# ── Optional monetization (Polar) ─────────────────────────────
# Set to "true" to enable subscriptions + one-time purchases.
POLAR_ENABLED=
# Organization access token. https://polar.sh -> Settings -> Developers
POLAR_ACCESS_TOKEN=
# Signing secret for the Polar webhook (Settings -> Webhooks)
POLAR_WEBHOOK_SECRET=
# Use "sandbox" while testing; omit or "production" when live.
POLAR_SERVER=production
# Required for signed playback of gated (paid) videos.
# Create a signing key in the Mux dashboard (Settings -> Signing Keys).
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=

# ── Assets / branding uploads ─────────────────────────────────
# Custom thumbnails + branding use Supabase Storage (buckets are created by
# the migrations), so no extra configuration is required.
