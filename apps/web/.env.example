# ─────────────────────────────────────────────────────────────
# PUBLIC config, inlined into the browser AND SSR bundles by Vite at build time
# (read via import.meta.env). Copy to `.env.local` for local dev; in CI/CD set
# these as build-time environment variables.
#
# These values are public — never put secrets here. Server-only secrets live in
# `.dev.vars` (local) / `wrangler secret put` (prod). See `.dev.vars.example`.
# ─────────────────────────────────────────────────────────────

# Supabase project URL + publishable (anon) key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Public base URL of the app (used for canonical URLs, sitemap, RSS, redirects).
VITE_APP_URL=http://localhost:3000

# Cloudflare Web Analytics beacon token (optional; Dashboard → Web Analytics).
VITE_CF_ANALYTICS_TOKEN=

# Cloudflare Stream customer code — your `customer-<CODE>` subdomain, found on the
# Stream dashboard. Used to build thumbnail/poster URLs. Public (safe to expose).
VITE_STREAM_CUSTOMER_CODE=
