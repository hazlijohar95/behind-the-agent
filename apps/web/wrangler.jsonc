{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "behindthecode",
  "compatibility_date": "2025-09-02",
  // `nodejs_compat` lets Node-style APIs (used by Supabase/Polar SDKs and the
  // seed scripts) run on the Workers runtime.
  "compatibility_flags": ["nodejs_compat"],
  // Custom Worker entry that re-exports the TanStack Start SSR fetch handler
  // (@tanstack/react-start/server-entry) AND adds a `scheduled` handler for the
  // Cron Trigger below (scheduled publish).
  "main": "./src/worker.ts",
  // R2 bucket for public media (custom video posters, branding/logo). Served by
  // the app's own /media/* route — native to the Worker, no Supabase Storage and
  // no external bucket domain. Local dev uses a miniflare-backed bucket.
  "r2_buckets": [{ "binding": "MEDIA", "bucket_name": "btd-media" }],
  "observability": { "enabled": true },
  "triggers": {
    // Cron Trigger → the Worker `scheduled()` handler (scheduled publish).
    "crons": ["*/5 * * * *"]
  }
  // Public config (VITE_*) is inlined at build time from the build environment
  // (see apps/web/.env / CI build vars), not declared here. Server-only secrets
  // are set with `wrangler secret put <NAME>`.
}
