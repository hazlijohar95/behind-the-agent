{
  "name": "behindthecode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "test": "vitest run",
    "setup": "bun install && supabase start && bun run seed",
    "clean": "turbo run clean && rm -rf node_modules",
    "seed": "bun run --cwd apps/web seed",
    "seed:admin": "bun run --cwd apps/web seed:admin"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@material-symbols/svg-400": "^0.44.12",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "tw-animate-css": "1.4.0"
  }
}
