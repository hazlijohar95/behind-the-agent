{
  "name": "@btc/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#lib/*": "./src/lib/*.ts",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "vite preview --port 3000",
    "preview": "vite preview --port 3000",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist .output .wrangler node_modules",
    "seed": "bun run scripts/seed.ts",
    "seed:admin": "bun run scripts/seed.ts --admin-only"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@btc/db": "*",
    "@btc/mux": "*",
    "@btc/ui": "*",
    "@mux/mux-player-react": "^3.13.0",
    "@mux/mux-uploader-react": "^1.5.0",
    "@polar-sh/sdk": "^0.47.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.0",
    "@tanstack/react-router-with-query": "^1.130.0",
    "@tanstack/react-start": "^1.168.0",
    "ai": "^6.0.195",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@btc/config": "*",
    "@cloudflare/vite-plugin": "^1.40.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@types/node": "^22.18.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wrangler": "^4.98.0"
  }
}
