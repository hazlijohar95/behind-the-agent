# ─────────────────────────────────────────────────────────────
# SERVER-ONLY secrets. Copy to `.dev.vars` and fill in.
# The Cloudflare Vite plugin loads this into the Worker's process.env (via
# nodejs_compat) for `vite dev` / `wrangler dev`.
#
# PUBLIC browser config (VITE_*) does NOT go here — it lives in `.env` /
# `.env.local` and is read through import.meta.env. See `.env.example`.
#
# In production set each of these with:  wrangler secret put <NAME>
# ─────────────────────────────────────────────────────────────

# ── Supabase data layer (@btc/db service-role client; also used by seed) ──
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ── Cloudflare Stream (video) ──
# Account id + an API token with the "Stream:Edit" permission. Used for direct
# uploads, deletes, the webhook subscription, and signed playback.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
# Webhook secret + signing key for gated/paid playback. Generate all three with
#   bun run --cwd apps/web stream-setup
# and paste the printed values here.
STREAM_WEBHOOK_SECRET=
STREAM_SIGNING_KEY_ID=
STREAM_SIGNING_JWK=

# ── Cron ──
# Authorizes the HTTP /api/cron/publish trigger. The Cloudflare Cron Trigger
# (every 5 min, see wrangler.jsonc) calls the Worker scheduled() handler directly
# and does not need this secret.
CRON_SECRET=

# ── Initial admin (seed scripts; first signup also becomes admin) ──
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# ── Optional: AI comment moderation ──
AI_MODERATION_ENABLED=
OPENAI_API_KEY=

# ── Optional: Polar monetization ──
POLAR_ENABLED=
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=production

# ── Optional sign-in providers (each auto-enables its method) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
RESEND_API_KEY=
EMAIL_FROM=
